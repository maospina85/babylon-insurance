{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["productCode", "version", "status", "modules"],
    "properties": {
      "productCode": {
        "bsonType": "string"
      },
      "version": {
        "bsonType": "string"
      },
      "status": {
        "bsonType": "string",
        "enum": ["ACTIVE", "INACTIVE"]
      },
      "modules": {
        "bsonType": "array",
        "minItems": 1,
        "items": {
          "bsonType": "object",
          "required": ["moduleId", "tiers"],
          "properties": {
            "moduleId": {
              "bsonType": "string",
              "enum": ["death", "disability", "accidents", "assistance"]
            },
            "tiers": {
              "bsonType": "array",
              "minItems": 1,
              "maxItems": 4
            }
          }
        }
      }
    }
  }
}
