# .env.example — Variables de entorno requeridas para Babylon Insurance Backend
# Este archivo SÍ se commitea. Nunca poner valores reales aquí.
# Copia a backend/.env y rellena los valores antes de ejecutar en local.

# MongoDB Atlas connection string
# Obtener en: cloud.mongodb.com → Connect → Drivers → Java
MONGODB_URI=mongodb+srv://babylon_app:PASSWORD@cluster0.xxxxx.mongodb.net/babylon

# Clave AES-256 en base64 (32 bytes)
# Generar con: node scripts/generate-key.js
BABYLON_ENCRYPTION_KEY=

# Origins permitidos para CORS (separados por coma)
# Local: http://localhost:3000
# Producción: URL de Cloud Run del frontend
ALLOWED_ORIGINS=http://localhost:3000

# Perfil activo de Spring Boot
# Opciones: local, production
SPRING_PROFILES_ACTIVE=local
